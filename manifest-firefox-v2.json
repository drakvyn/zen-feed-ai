{
  "manifest_version": 2,
  "name": "LinkedIn: hide AI posts",
  "version": "1.1.0",
  "description": "Hide AI/LLM posts in your LinkedIn feed—built-in keywords, custom lines, toggle in the popup. Chrome & Firefox. Local storage only.",
  "icons": {
    "128": "icon.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "LinkedIn — hide AI posts"
  },
  "permissions": [
    "storage",
    "tabs",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-hide-ai@example.com",
      "strict_min_version": "57.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
