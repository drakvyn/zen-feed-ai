{
  "manifest_version": 3,
  "name": "LinkedIn: hide AI posts",
  "version": "1.0.0",
  "description": "Hide AI-related posts in your LinkedIn feed (ChatGPT, LLMs, and more).",
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "LinkedIn — hide AI posts"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-hide-ai@example.com",
      "strict_min_version": "121.0"
    }
  }
}
