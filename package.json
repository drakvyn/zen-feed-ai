{
  "name": "linkedin-hide-ai-extension",
  "private": true,
  "scripts": {
    "lint:firefox": "web-ext lint --source-dir .",
    "build:firefox": "web-ext build --source-dir . --artifacts-dir web-ext-artifacts --overwrite-dest",
    "pack:temp": "web-ext build --source-dir . --artifacts-dir . --filename linkedin-hide-ai-dev.xpi --overwrite-dest --ignore-files \"node_modules/**\" \"web-ext-artifacts/**\" \"package-lock.json\""
  },
  "devDependencies": {
    "web-ext": "^8.3.0"
  }
}
